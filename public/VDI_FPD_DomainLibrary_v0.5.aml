  <RoleClassLib Name="VDI_FPD_RoleClassLib">
    <Description>Semantic model of the FPD per VDI/VDE 3682. Flat layout with explicit inheritance via RefBaseClassPath.</Description>
    <Version>1.0.0</Version>
    <RoleClass Name="FPD_Process" RefBaseClassPath="AutomationMLBaseLibrariesAMLEd22_11_0@AutomationMLBaseRoleClassLib/AutomationMLBaseRole/Structure">
      <Description>Process (Part 2, Fig. 2). Aggregates states (2..*), system limit (1), and process operators (1..*).</Description>
      <Version>1.0.0</Version>
      <Attribute Name="refObj" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_AttributeTypeLib/refObj">
        <Description>IDREF to the parent process operator whose decomposition this process represents.</Description>
      </Attribute>
    </RoleClass>
    <RoleClass Name="FPD_SystemLimit">
      <Description>System limit (Part 1, p. 9). Peer aggregate of the process, not a container.</Description>
      <Version>1.0.0</Version>
      <Attribute Name="Identification" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_AttributeTypeLib/FPD_Identification">
