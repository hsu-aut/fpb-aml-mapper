  <AttributeTypeLib Name="VDI_FPD_DI_AttributeTypeLib">
    <Description>Diagram Interchange attributes, aligned with OMG DD/DI terminology (DC::Bounds, DC::Point, DI::Waypoint).</Description>
    <Version>1.0.0</Version>
    <AttributeType Name="FPD_Bounds" AttributeDataType="xs:string">
      <Description>A rectangular area defined by a top-left (x, y) location and a size (width, height) along the x-y axes (cf. DC::Bounds).</Description>
      <Version>1.0.0</Version>
      <Attribute Name="position" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_DI_AttributeTypeLib/FPD_Point">
        <Attribute Name="x" AttributeDataType="xs:double" />
        <Attribute Name="y" AttributeDataType="xs:double" />
      </Attribute>
      <Attribute Name="width" AttributeDataType="xs:double" />
      <Attribute Name="height" AttributeDataType="xs:double" />
    </AttributeType>
    <AttributeType Name="FPD_Waypoint" AttributeDataType="xs:string">
      <Description>A routing point along a connection path (cf. DI::Waypoint).</Description>
      <Version>1.0.0</Version>
      <Attribute Name="position" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_DI_AttributeTypeLib/FPD_Point">
        <Attribute Name="x" AttributeDataType="xs:double" />
        <Attribute Name="y" AttributeDataType="xs:double" />
      </Attribute>
    </AttributeType>
    <AttributeType Name="FPD_Point" AttributeDataType="xs:string">
